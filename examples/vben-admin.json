{
  "name": "Vben Admin Default",
  "packageName": "@local/element-plus-theme-vben-admin",
  "elementPlusVersion": "latest",
  "density": "default",
  "colors": {
    "white": "#ffffff",
    "black": "#000000",
    "primary": "#006be6",
    "success": "#57d188",
    "warning": "#efbd48",
    "danger": "#ff3860",
    "error": "#ff3860",
    "info": "#909298"
  },
  "radius": {
    "base": "0.5rem",
    "small": "0.375rem",
    "round": "9999px",
    "circle": "100%"
  },
  "text": {
    "primary": "#323639",
    "regular": "#323639",
    "secondary": "#71717a",
    "placeholder": "#9ca4af",
    "disabled": "#9ca4af"
  },
  "border": {
    "base": "#e4e4e7",
    "light": "#e4e4e7",
    "lighter": "#e4e4e7",
    "extraLight": "#e4e4e7",
    "dark": "#e4e4e7",
    "darker": "#71717a",
    "width": "1px",
    "style": "solid",
    "hover": "#f4f4f5"
  },
  "fill": {
    "base": "#f4f4f5",
    "light": "#f4f4f5",
    "lighter": "#fafafa",
    "extraLight": "#fafafa",
    "dark": "#ebedf0",
    "darker": "#e6e8eb",
    "blank": "#ffffff"
  },
  "background": {
    "page": "#f1f3f6",
    "base": "#ffffff",
    "overlay": "#ffffff"
  },
  "shadow": {
    "base": "0 12px 32px 4px rgba(0, 0, 0, 0.04), 0 8px 20px rgba(0, 0, 0, 0.08)",
    "light": "0 0 12px rgba(0, 0, 0, 0.08)",
    "lighter": "0 0 6px rgba(0, 0, 0, 0.08)",
    "dark": "0 16px 48px 16px rgba(0, 0, 0, 0.08), 0 12px 32px rgba(0, 0, 0, 0.12)"
  },
  "typography": {
    "htmlFontSize": "16px",
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'",
    "extraLarge": "20px",
    "large": "18px",
    "medium": "16px",
    "base": "16px",
    "small": "14px",
    "extraSmall": "12px"
  },
  "componentSize": {
    "large": "40px",
    "default": "32px",
    "small": "24px"
  },
  "overlay": {
    "base": "rgba(0, 0, 0, 0.45)",
    "light": "rgba(0, 0, 0, 0.35)",
    "lighter": "rgba(0, 0, 0, 0.2)"
  },
  "mask": {
    "base": "rgba(255, 255, 255, 0.9)",
    "extraLight": "rgba(255, 255, 255, 0.3)"
  },
  "breakpoints": {
    "sm": "768px",
    "md": "992px",
    "lg": "1200px",
    "xl": "1920px"
  },
  "scssOverrides": {
    "card": "('border-color': #e4e4e7, 'border-radius': 0.5rem, 'padding': 20px, 'bg-color': #ffffff)",
    "z-index": "('normal': 1, 'top': 1000, 'popper': 2000)"
  },
  "cssOverrides": {
    "light": "",
    "dark": ""
  },
  "compatibility": {
    "vben": true
  }
}
